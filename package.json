{
  "name": "no.almli.thermostat",
  "version": "1.0.0",
  "description": "Virtual thermostat",
  "main": "app.ts",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "pretest": "npm run test:typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:typecheck": "tsc --noEmit -p tsconfig.eslint.json",
    "posttest": "homey app validate && prettier --write app.json",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "lint": "npm run format:check && eslint app.ts drivers lib tests vitest.config.ts"
  },
  "author": "Bjørnar Almli",
  "license": "ISC",
  "dependencies": {
    "homey-api": "^3.19.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/homey": "npm:homey-apps-sdk-v3-types@^0.3.12",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
